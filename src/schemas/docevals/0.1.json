{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docevals:frontmatter:0.1",
  "title": "docevals frontmatter",
  "description": "Page-level eval declarations for docevals under the `evals` key. Evals are graded by code (command/tool graders), an LLM judge, or a human.",
  "type": "object",
  "properties": {
    "evals": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/evalEntry" },
          "description": "Shorthand: just the list of evals for this page."
        },
        { "$ref": "#/$defs/evalsObject" }
      ]
    }
  },
  "$defs": {
    "evalsObject": {
      "type": "object",
      "properties": {
        "suite": {
          "type": "string",
          "description": "Named suite from docevals.config.yaml whose evals apply to this page. Page-level evals win on name collision."
        },
        "skip": {
          "type": "boolean",
          "default": false,
          "description": "Skip this page entirely (reported as skipped)."
        },
        "generatedBy": {
          "type": "string",
          "description": "Model that generated this page's content, if any. docevals warns when it equals the judge model (self-preference bias)."
        },
        "evals": {
          "type": "array",
          "items": { "$ref": "#/$defs/evalEntry" }
        }
      },
      "additionalProperties": false
    },
    "evalEntry": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/evalReference" },
        { "$ref": "#/$defs/inlineEval" }
      ]
    },
    "evalReference": {
      "type": "object",
      "required": ["use"],
      "properties": {
        "use": {
          "type": "string",
          "minLength": 1,
          "description": "Name of an eval defined in docevals.config.yaml."
        },
        "type": { "$ref": "#/$defs/evalType" },
        "skip": { "type": "boolean" },
        "severity": { "$ref": "#/$defs/severity" },
        "options": { "type": "object" }
      },
      "additionalProperties": false
    },
    "inlineEval": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Unique (per page) kebab-case eval name."
        },
        "assertion": {
          "type": "string",
          "minLength": 1,
          "description": "The testable assertion, in plain language."
        },
        "type": { "$ref": "#/$defs/evalType" },
        "grader": { "$ref": "#/$defs/grader" },
        "evidence": {
          "type": "string",
          "description": "Hint scoping where the judge should look for evidence."
        },
        "examples": {
          "type": "object",
          "properties": {
            "pass": { "type": "string" },
            "fail": { "type": "string" }
          },
          "additionalProperties": false
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Command to execute for command-graded evals. {file} is replaced with the page path. Exit 0 = pass. Omit to have docevals generate a check script from the assertion."
        },
        "successExitCodes": {
          "type": "array",
          "items": { "type": "integer" },
          "default": [0]
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "generated": {
          "type": "object",
          "required": ["assertionHash"],
          "properties": {
            "assertionHash": {
              "type": "string",
              "description": "sha256 of the assertion when the script was generated. A mismatch triggers regeneration."
            }
          },
          "additionalProperties": false
        },
        "options": { "type": "object" },
        "severity": { "$ref": "#/$defs/severity" },
        "skip": { "type": "boolean" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "grader": { "const": "llm" } }
          },
          "then": { "required": ["assertion"] }
        },
        {
          "if": { "not": { "required": ["grader"] } },
          "then": { "required": ["assertion"] }
        },
        {
          "if": {
            "properties": { "grader": { "const": "command" } },
            "required": ["grader"]
          },
          "then": {
            "anyOf": [{ "required": ["assertion"] }, { "required": ["command"] }]
          }
        }
      ]
    },
    "evalType": {
      "enum": ["capability", "regression"],
      "default": "regression"
    },
    "severity": { "enum": ["error", "warning", "info"] },
    "grader": {
      "type": "string",
      "pattern": "^(llm|command|human|tool:[a-z0-9][a-z0-9-]*)$",
      "default": "llm"
    }
  }
}
